{
  "name": "angular-todo-app",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "serve:angular": "ng serve --proxy-config proxy.conf.json",
    "start": "concurrently \"npm run server\" \"npm run serve:angular\"",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:angular-todo-app": "node dist/angular-todo-app/server/server.mjs",
    "server": "json-server --watch db.json --port 3000"
  },
  "private": true,
  "packageManager": "npm@11.12.1",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-server": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/ssr": "^21.2.5",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "express": "^5.1.0",
    "jqwidgets-ng": "^25.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.5",
    "@angular/cli": "^21.2.5",
    "@angular/compiler-cli": "^21.2.0",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "concurrently": "^9.2.1",
    "json-server": "^1.0.0-beta.15",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  }
}
