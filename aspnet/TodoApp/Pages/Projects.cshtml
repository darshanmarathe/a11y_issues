@page
@model ProjectsPageModel
@{
    ViewData["Title"] = "Projects";
}

<div class="content-header mt-2">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-8">
                <h1 class="m-0"><i class="fas fa-folder-open"></i> Projects Master</h1>
            </div>
            <div class="col-sm-4">
                <button class="btn btn-primary float-right" onclick="openAddModal()">
                    <i class="fas fa-plus-circle"></i> Add Project
                </button>
            </div>
        </div>
    </div>
</div>

<div class="content">
    <div class="container-fluid">
        <!-- Search -->
        <div class="search-box">
            <i class="fas fa-search search-icon"></i>
            <input type="text" class="form-control form-control-lg" id="searchInput" placeholder="Search projects by name or description..." />
        </div>
        
        <!-- Table -->
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h3 class="card-title"><i class="fas fa-table"></i> Projects List</h3>
                <div class="card-tools">
                    <button class="btn btn-sm btn-primary" onclick="openAddModal()">
                        <i class="fas fa-plus"></i> New
                    </button>
                </div>
            </div>
            <div class="card-body p-0">
                <table class="table table-bordered table-striped table-hover" id="projectsTable">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Name</th>
                            <th>Description</th>
                            <th>Created Date</th>
                            <th>Active</th>
                            <th>Todos Count</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Project Modal -->
<div class="modal fade" id="projectModal" tabindex="-1" aria-labelledby="modalTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h4 class="modal-title" id="modalTitle"><i class="fas fa-plus-circle"></i> Add Project</h4>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <form id="projectForm">
                    <input type="hidden" id="projectId" />
                    <div class="form-group">
                        <label for="projectName"><i class="fas fa-folder"></i> Name *</label>
                        <input type="text" class="form-control" id="projectName" required placeholder="Enter project name" />
                    </div>
                    <div class="form-group">
                        <label for="projectDescription"><i class="fas fa-align-left"></i> Description</label>
                        <textarea class="form-control" id="projectDescription" rows="3" placeholder="Enter project description"></textarea>
                    </div>
                    <div class="form-group">
                        <div class="custom-control custom-switch">
                            <input type="checkbox" class="custom-control-input" id="projectActive" checked />
                            <label class="custom-control-label" for="projectActive"><i class="fas fa-toggle-on"></i> Active</label>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-danger" id="deleteProjectBtn" style="display:none;" onclick="deleteProject()">
                    <i class="fas fa-trash"></i> Delete
                </button>
                <button type="button" class="btn btn-secondary" data-dismiss="modal">
                    <i class="fas fa-times"></i> Close
                </button>
                <button type="button" class="btn btn-primary" onclick="saveProject()">
                    <i class="fas fa-save"></i> Save
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    let projects = [];
    let projectModal;

    $(document).ready(function() {
        projectModal = new bootstrap.Modal(document.getElementById('projectModal'));
        
        loadProjects();
        
        // Search functionality
        $('#searchInput').on('keyup', function() {
            const searchTerm = $(this).val().toLowerCase();
            const filtered = projects.filter(project => 
                project.name.toLowerCase().includes(searchTerm) ||
                (project.description && project.description.toLowerCase().includes(searchTerm))
            );
            renderTable(filtered);
        });
    });

    function loadProjects() {
        $.get('/api/projects', function(data) {
            projects = data;
            renderTable();
        });
    }

    function renderTable(data) {
        data = data || projects;
        const tbody = $('#projectsTable tbody');
        tbody.empty();
        
        if (data.length === 0) {
            tbody.append('<tr><td colspan="7" class="text-center text-muted py-4"><i class="fas fa-folder-open fa-2x mb-2 d-block"></i>No projects found</td></tr>');
            return;
        }
        
        data.forEach(project => {
            const row = `
                <tr>
                    <td><strong>${project.id}</strong></td>
                    <td><i class="fas fa-folder text-primary"></i> ${escapeHtml(project.name)}</td>
                    <td>${escapeHtml(project.description || '').substring(0, 50)}${(project.description || '').length > 50 ? '...' : ''}</td>
                    <td><i class="fas fa-calendar-alt"></i> ${formatDate(project.createdDate)}</td>
                    <td>${project.isActive ? '<i class="fas fa-check-circle text-success"></i> Yes' : '<i class="fas fa-times-circle text-danger"></i> No'}</td>
                    <td><span class="badge badge-info">${project.todos ? project.todos.length : 0} todos</span></td>
                    <td>
                        <button class="btn btn-sm btn-info" onclick="openEditModal(${project.id})">
                            <i class="fas fa-edit"></i> Edit
                        </button>
                    </td>
                </tr>
            `;
            tbody.append(row);
        });
    }

    function openAddModal() {
        $('#modalTitle').html('<i class="fas fa-plus-circle"></i> Add Project');
        $('#projectForm')[0].reset();
        $('#projectId').val('');
        $('#projectActive').prop('checked', true);
        $('#deleteProjectBtn').hide();
        projectModal.show();
    }

    function openEditModal(projectId) {
        const project = projects.find(p => p.id === projectId);
        if (!project) return;
        
        $('#modalTitle').html('<i class="fas fa-edit"></i> Edit Project');
        $('#projectId').val(project.id);
        $('#projectName').val(project.name);
        $('#projectDescription').val(project.description || '');
        $('#projectActive').prop('checked', project.isActive);
        $('#deleteProjectBtn').show();
        projectModal.show();
    }

    function saveProject() {
        const projectId = $('#projectId').val();
        const projectData = {
            name: $('#projectName').val(),
            description: $('#projectDescription').val(),
            isActive: $('#projectActive').is(':checked')
        };
        
        if (!projectData.name) {
            alert('Name is required');
            return;
        }
        
        const url = projectId ? `/api/projects/${projectId}` : '/api/projects';
        const method = projectId ? 'PUT' : 'POST';
        
        $.ajax({
            url: url,
            method: method,
            contentType: 'application/json',
            data: JSON.stringify(projectData),
            success: function() {
                projectModal.hide();
                loadProjects();
            },
            error: function(xhr) {
                alert('Error saving project: ' + xhr.responseText);
            }
        });
    }

    function deleteProject() {
        const projectId = $('#projectId').val();
        if (!projectId) return;
        
        if (confirm('Are you sure you want to delete this project?')) {
            $.ajax({
                url: `/api/projects/${projectId}`,
                method: 'DELETE',
                success: function() {
                    projectModal.hide();
                    loadProjects();
                },
                error: function(xhr) {
                    alert('Error deleting project: ' + xhr.responseText);
                }
            });
        }
    }

    function escapeHtml(text) {
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }

    function formatDate(dateString) {
        const date = new Date(dateString);
        return date.toLocaleDateString();
    }
</script>
}
